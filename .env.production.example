APP_NAME=LATSAR
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.tld
ASSET_URL=
ASSET_VERSION=

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=latsar_prod
DB_USERNAME=latsar_user
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_IDLE_TIMEOUT=60
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=your-domain.tld
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

SECURITY_HEADERS_ENABLED=true
SECURITY_HEADERS_HSTS_ENABLED=true
SECURITY_HEADERS_HSTS_MAX_AGE=31536000
SECURITY_HEADERS_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HEADERS_HSTS_PRELOAD=false
SECURITY_HEADERS_CSP_REPORT_ONLY=
OPS_MAX_FAILED_JOBS=0
OPS_MAX_PENDING_JOBS=500
OPS_HEALTH_LOG_FILE=logs/ops-health.log
SCHEMA_METADATA_TTL_SECONDS=900
DASHBOARD_QUERY_PROFILE_ENABLED=false
DASHBOARD_SLOW_QUERY_MS=80
DASHBOARD_TOTAL_QUERY_BUDGET_MS=300
DASHBOARD_PROFILE_MAX_LOGGED_QUERIES=12

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=your-domain.tld
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

CACHE_STORE=database
# CACHE_PREFIX=latsar-prod-cache

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@your-domain.tld
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_ACTION=login

VITE_APP_NAME="${APP_NAME}"
